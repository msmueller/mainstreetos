# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://djbtlhuncpxbxtjbrhsc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenRouter (legacy — may still be referenced by older agents)
OPENROUTER_API_KEY=your-openrouter-key-here

# Anthropic (Claude SDK — primary LLM provider for agents)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Notion (Phase 12.13 — AI drafts)
# Internal integration secret (create at https://www.notion.so/profile/integrations,
# then share the "MSOS AI Drafts" root page with this integration under Connections).
# Paste the token EXACTLY as Notion shows it. New-style tokens begin with "ntn_...";
# older ones begin with "secret_...". Both are valid — do not add or strip any prefix.
NOTION_API_KEY=ntn_your-notion-internal-integration-token
# Root page that AI draft children are created under.
NOTION_AI_DRAFTS_ROOT_PAGE_ID=34a9af0754ec81758918e4147fa10d82

# Click-wrap NDA → Notion LEADS write-back (Build A, 2026-07-02).
# Ships dark: set to "on" only after a successful test-envelope pass.
# Controls ALL Notion writes from lib/notion-sync-clickwrap.ts (completion
# path AND the /api/sign/backfill-notion-sync backfill).
NDA_NOTION_SYNC=off

# Lead auto-route trigger (2026-07-02). Vercel cron polls Notion LEADS every
# 10 min and routes fresh unrouted buyer leads through the Lead Router
# (Email 1 + NDA link). Ships dark: set "on" only after a dry-run check.
LEAD_AUTOROUTE=off
# Vercel includes this automatically in cron request auth headers once set.
CRON_SECRET=generate-with-openssl-rand-hex-32

# Per-listing public "Start NDA" page (Build Spec v1.0). Reusable public link
# (e.g. /nda/yogi-international) that lets a non-BBS prospect self-identify and
# complete the NDA + Buyer Profile with no pre-minted per-buyer link.
# Ships dark: page returns 404 unless this is explicitly "on".
NDA_PUBLIC_PAGE=off
# Cloudflare Turnstile (bot check on the public page). Server secret + public
# site key. Create at https://dash.cloudflare.com → Turnstile.
# Anti-abuse FAILS CLOSED — if the secret is unset, the public mint is blocked.
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
# Email OTP delivery reuses the click-wrap Resend config already required by
# lib/email.ts: RESEND_API_KEY, EMAIL_FROM, EMAIL_REPLY_TO, BROKER_NOTIFY_TO.
# Server-side envelope mint reuses: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY.

# Stripe (Phase 1 billing)
STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
